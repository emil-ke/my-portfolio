		bottom: 0;
		height: 200px;
		width: 100%;
	}

	footer {
		background: var(--accent_d);
		color: var(--accent);
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem 4%;
		height: 100%;
		width: 100%;
	}

	.left {
