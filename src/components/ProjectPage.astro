---
const { title, images = [], writing_page = false } = Astro.props;

let pageback_link: string;
let pageback_name: string;
let mobile_pageback_name: string;

if (writing_page) {
	pageback_link = "/writing";
	pageback_name = "the writing collection page";
	mobile_pageback_name = "writing";
} else {
	pageback_link = "/#projects";
	pageback_name = "the list of projects";
	mobile_pageback_name = "projects";
}
---

<style>
	.projectWrapper {
		width: 92%;
		display: flex;
		flex-direction: column;
		margin: 0 auto;
		padding: 16rem 0 12rem 0;
	}

	.projectContent {
		display: flex;
		flex-direction: row;
		min-height: 100vh;
	}

	.projectTitle {
		margin-bottom: 6rem;
	}

	.projectText {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
	}

	.projectText p {
		text-indent: 1.5rem;
		margin: 0 0 1.4rem;
	}

	.projectImages {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 2rem;
	}

	.projectImages img {
		max-width: 80%;
		margin-bottom: 2rem;
	}

	.goBackBtn {
		color: var(--accent_d);
		padding: 1rem 2rem;
		transition: all 0.2s ease-in-out;
		border: 2px solid var(--accent_l);
		display: inline-block;
		white-space: nowrap;
	}

	.goBackBtn:hover {
		color: var(--text-color);
		border: 2px solid var(--accent-brighter);
	}

	.desktopBackText {
		display: inline;
	}

	.mobileBackText {
		display: none;
	}

	@media (max-width: 1020px) {
		.projectContent {
			flex-direction: column;
		}

		.projectImages {
			align-items: center;
			flex-direction: row;
			flex-wrap: wrap;
			justify-content: center;
			margin-top: 3rem;
			gap: 2rem;
		}

		.projectImages img {
			max-width: 90vw;
			margin-bottom: 0;
		}
	}

	@media (max-width: 600px) {
		.desktopBackText {
			display: none;
		}

		.mobileBackText {
			display: inline;
		}
	}
</style>

<div class="projectWrapper">
	<div class="projectContent">
		<div class="projectText">
			<h4 class="projectTitle">{title}</h4>
			<slot />
		</div>

		<div class="projectImages">
			{images.map((src) => <img src={src} alt={title + " screenshot"} />)}
		</div>
	</div>

	<div class="spacer"></div>

	<div class="backBtnWrapper">
		<a class="goBackBtn" href={pageback_link}>
			←
			<span style="margin: 1rem;"></span>

			<span class="desktopBackText">
				back to {pageback_name}
			</span>

			<span class="mobileBackText"> go back </span>
		</a>
	</div>
</div>
